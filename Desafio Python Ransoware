# 🔐 5. Ransomware Simulado

## 📌 Funcionamento

O script executa as seguintes ações:

1. Cria arquivos de teste
2. Aplica transformação reversível (simulação de criptografia)
3. Renomeia arquivos
4. Gera nota de resgate fictícia
5. Permite restauração dos arquivos

---

## 💻 Código: ransomware_sim.py

```python
from pathlib import Path
import os

LAB_DIR = Path("lab_data/samples")
RANSOM_NOTE = LAB_DIR / "LEIA-ME-RESGATE.txt"
KEY_FILE = LAB_DIR / ".lab_key"
TARGET_EXTENSIONS = [".txt", ".md", ".csv"]
ENCRYPTED_EXTENSION = ".lablocked"


def ensure_lab_environment():
    LAB_DIR.mkdir(parents=True, exist_ok=True)


def create_test_files():
    ensure_lab_environment()

    files = {
        "relatorio.txt": "Relatório de teste.",
        "clientes.csv": "id,nome\n1,Ana\n2,Caio",
        "notas.md": "# Notas de laboratório"
    }

    for filename, content in files.items():
        file_path = LAB_DIR / filename
        file_path.write_text(content, encoding="utf-8")

    print("[OK] Arquivos criados.")


def generate_key():
    key = os.urandom(1)
    KEY_FILE.write_bytes(key)
    return key


def load_key():
    return KEY_FILE.read_bytes()


def xor_transform(data, key):
    return bytes(b ^ key[0] for b in data)


def encrypt_files():
    key = generate_key()

    for file_path in LAB_DIR.iterdir():
        if file_path.suffix in TARGET_EXTENSIONS:
            data = file_path.read_bytes()
            encrypted = xor_transform(data, key)

            new_path = file_path.with_suffix(file_path.suffix + ENCRYPTED_EXTENSION)
            new_path.write_bytes(encrypted)
            file_path.unlink()

    RANSOM_NOTE.write_text("Simulação de ransomware - ambiente seguro")


def decrypt_files():
    key = load_key()

    for file_path in LAB_DIR.iterdir():
        if file_path.name.endswith(ENCRYPTED_EXTENSION):
            data = file_path.read_bytes()
            decrypted = xor_transform(data, key)

            original_name = file_path.name.replace(ENCRYPTED_EXTENSION, "")
            restored = LAB_DIR / original_name
            restored.write_bytes(decrypted)
            file_path.unlink()
```

